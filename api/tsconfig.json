{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@nexus/shared": ["../../packages/shared/src/index.ts"],
      "@nexus/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src", "prisma/seed.ts"]
}
