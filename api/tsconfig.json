{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@nexus/shared": ["./shared/dist/index.d.ts"],
      "@nexus/shared/*": ["./shared/dist/*.d.ts"]
    }
  },
  "include": ["src", "prisma/seed.ts"]
}
