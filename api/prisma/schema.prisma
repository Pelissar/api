generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AdminRole {
  ADMIN
  SUPORTE
  REVENDEDOR
}

enum ClientStatus {
  ATIVO
  INATIVO
}

enum PlanInterval {
  MENSAL
  ANUAL
}

enum PlanStatus {
  ATIVO
  INATIVO
}

enum LicenseType {
  MENSAL
  ANUAL
}

enum LicenseStatus {
  ATIVA
  SUSPENSA
  EXPIRADA
  CANCELADA
  TESTE
}

enum ReleaseChannel {
  STABLE
  BETA
}

enum AppEdition {
  EMPRESARIAL
  RESTAURANTE
}

enum DesktopRecordType {
  COMPANY
  CUSTOMER
  PRODUCT
  ORDER
  USER
}

enum SupportTicketStatus {
  ABERTO
  EM_ATENDIMENTO
  AGUARDANDO_CLIENTE
  RESOLVIDO
  FECHADO
}

enum SupportTicketPriority {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

enum SupportTicketSenderType {
  CLIENTE
  ADMIN
}

model Tenant {
  id                  String               @id @default(uuid())
  name                String
  slug                String               @unique
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  adminUsers          AdminUser[]
  clients             Client[]
  plans               Plan[]
  licenses            License[]
  appVersions         AppVersion[]
  desktopRecords      DesktopRecord[]
  auditLogs           AuditLog[]
  portalUsers         PortalUser[]
  portalRefreshTokens PortalRefreshToken[]
  portalResetTokens   PortalPasswordResetToken[]
  supportTickets      SupportTicket[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
}

model AdminUser {
  id                 String               @id @default(uuid())
  tenantId           String
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  email              String               @unique
  passwordHash       String
  role               AdminRole            @default(ADMIN)
  isActive           Boolean              @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  passwordResetTokens PasswordResetToken[]
  supportTicketMessages SupportTicketMessage[]
}

model RefreshToken {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  tokenHash   String
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([adminUserId])
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  tokenHash   String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Client {
  id        String       @id @default(uuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  tradeName String?
  cpfCnpj   String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  notes     String?
  status    ClientStatus @default(ATIVO)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  licenses  License[]
  portalUsers PortalUser[]
  supportTickets SupportTicket[]

  @@unique([tenantId, cpfCnpj])
  @@index([tenantId, name])
}

model Plan {
  id           String                       @id @default(uuid())
  tenantId     String
  tenant       Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  interval     PlanInterval
  price        Decimal                      @db.Decimal(10, 2)
  description  String?
  deviceLimit  Int
  features     Json
  enabledEditions AppEdition[]                @default([EMPRESARIAL])
  status       PlanStatus                   @default(ATIVO)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  licenses     License[]
  appVersions  AppVersionPlanPermission[]

  @@unique([tenantId, name])
  @@index([tenantId, name])
}

model License {
  id              String                          @id @default(uuid())
  tenantId        String
  tenant          Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String                          @unique
  clientId        String
  client          Client                          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  planId          String
  plan            Plan                            @relation(fields: [planId], references: [id], onDelete: Restrict)
  type            LicenseType
  status          LicenseStatus                   @default(ATIVA)
  activatedAt     DateTime?
  expiresAt       DateTime?
  devicesAllowed  Int                             @default(1)
  notes           String?
  lastValidationAt DateTime?
  minVersion      String?
  maxVersion      String?
  canUpdate       Boolean                         @default(true)
  canUseBeta      Boolean                         @default(false)
  enabledEditions AppEdition[]                    @default([EMPRESARIAL])
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  deviceActivations DeviceActivation[]
  appVersions     AppVersionLicensePermission[]

  @@index([tenantId, status])
  @@index([clientId])
  @@index([planId])
}

model DeviceActivation {
  id                String   @id @default(uuid())
  licenseId         String
  license           License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  deviceFingerprint String
  deviceName        String?
  appVersion        String?
  lastSeenAt        DateTime @default(now())
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([licenseId, deviceFingerprint])
  @@index([deviceFingerprint])
}

model AppVersion {
  id                    String                         @id @default(uuid())
  tenantId              String
  tenant                Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  version               String
  buildNumber           Int
  releaseNotes          String
  fileName              String
  filePath              String
  checksum              String
  fileSize              Int
  releaseChannel        ReleaseChannel                 @default(STABLE)
  isMandatory           Boolean                        @default(false)
  isActive              Boolean                        @default(true)
  allowAllActiveLicenses Boolean                       @default(true)
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  licensePermissions    AppVersionLicensePermission[]
  planPermissions       AppVersionPlanPermission[]

  @@unique([tenantId, version, buildNumber, releaseChannel])
  @@index([tenantId, isActive, releaseChannel])
}

model AppVersionLicensePermission {
  id           String     @id @default(uuid())
  appVersionId String
  appVersion   AppVersion @relation(fields: [appVersionId], references: [id], onDelete: Cascade)
  licenseId    String
  license      License    @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([appVersionId, licenseId])
}

model AppVersionPlanPermission {
  id           String     @id @default(uuid())
  appVersionId String
  appVersion   AppVersion @relation(fields: [appVersionId], references: [id], onDelete: Cascade)
  planId       String
  plan         Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([appVersionId, planId])
}

model AuditLog {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adminUserId String?
  adminUser  AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([tenantId, createdAt])
}

model PortalUser {
  id               String                    @id @default(uuid())
  tenantId         String
  tenant           Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId         String
  client           Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name             String
  email            String
  passwordHash     String
  isActive         Boolean                   @default(true)
  mustResetPassword Boolean                  @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  refreshTokens    PortalRefreshToken[]
  passwordResetTokens PortalPasswordResetToken[]
  supportTickets   SupportTicket[]
  supportMessages  SupportTicketMessage[]

  @@unique([tenantId, email])
  @@index([tenantId, clientId])
}

model PortalRefreshToken {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  tokenHash    String
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([portalUserId])
}

model PortalPasswordResetToken {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  tokenHash    String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime   @default(now())
}

model SupportTicket {
  id           String               @id @default(uuid())
  tenantId     String
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  portalUserId String?
  portalUser   PortalUser?          @relation(fields: [portalUserId], references: [id], onDelete: SetNull)
  subject      String
  category     String?
  status       SupportTicketStatus  @default(ABERTO)
  priority     SupportTicketPriority @default(NORMAL)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  closedAt     DateTime?
  messages     SupportTicketMessage[]

  @@index([tenantId, status, updatedAt])
  @@index([clientId, createdAt])
}

model SupportTicketMessage {
  id           String                  @id @default(uuid())
  ticketId     String
  ticket       SupportTicket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType   SupportTicketSenderType
  adminUserId  String?
  adminUser    AdminUser?              @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  portalUserId String?
  portalUser   PortalUser?             @relation(fields: [portalUserId], references: [id], onDelete: SetNull)
  message      String
  createdAt    DateTime                @default(now())

  @@index([ticketId, createdAt])
}

model DesktopRecord {
  id         String            @id
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recordType DesktopRecordType
  payload    Json
  isDeleted  Boolean           @default(false)
  updatedAt  DateTime
  createdAt  DateTime          @default(now())

  @@index([tenantId, recordType, updatedAt])
  @@index([tenantId, isDeleted, updatedAt])
}
